# Database (Render PostgreSQL connection string, or Supabase direct connection)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (Render Redis connection string)
REDIS_URL=redis://localhost:6379

# Gemini AI — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Auth — from https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# App
PORT=3001
# Set to your Render frontend URL in production (e.g. https://academic-success-client.onrender.com)
CLIENT_URL=http://localhost:5173
